<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyWhoosh 8-Week Build Plan</title>
    <!-- Mobile optimization for Z Fold 4 -->
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Training Log">
    <meta name="apple-mobile-web-app-title" content="Training Log">
    <meta name="theme-color" content="#2563eb">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 1rem;
        }
        .hidden { display: none; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .copy-toast {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            display: none;
            z-index: 100;
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen text-gray-800">

    <div id="toast" class="copy-toast">Copied to clipboard!</div>

    <div class="container">
        <header class="bg-white p-6 rounded-xl shadow-lg mb-6 border-b-4 border-blue-600">
            <div class="w-full mb-4">
                <h1 class="text-3xl font-bold text-gray-900">Training Log</h1>
                <div class="flex items-center space-x-2 mt-1">
                    <span class="bg-green-100 text-green-800 text-xs font-bold px-2.5 py-0.5 rounded">FTP: 223W</span>
                    <span class="text-gray-500 text-xs italic">8-Week Build Phase</span>
                </div>
            </div>
            <div class="flex space-x-2 flex-wrap justify-center w-full">
                <button id="cycling-btn" class="bg-blue-600 text-white font-medium py-2 px-4 rounded-full shadow-md hover:bg-blue-700 transition duration-300 mb-2 flex-1">Cycling</button>
                <button id="calisthenics-btn" class="bg-gray-300 text-gray-700 font-medium py-2 px-4 rounded-full shadow-md hover:bg-gray-400 transition duration-300 mb-2 flex-1">Strength</button>
                <button id="nutrition-btn" class="bg-gray-300 text-gray-700 font-medium py-2 px-4 rounded-full shadow-md hover:bg-gray-400 transition duration-300 mb-2 flex-1">Nutrition</button>
            </div>
        </header>

        <!-- Tab Content: Cycling -->
        <main id="cycling-content" class="bg-white p-6 rounded-xl shadow-lg">
            <h2 class="text-2xl font-bold mb-2">Build Plan: 8 Weeks</h2>
            <div class="p-4 bg-blue-50 rounded-lg mb-4 border-l-4 border-blue-500">
                <div class="flex justify-between items-start mb-2">
                    <h3 class="font-bold text-blue-900">Current Goal</h3>
                    <span class="bg-blue-200 text-blue-800 text-[10px] px-2 py-0.5 rounded font-bold">BLOCK 1</span>
                </div>
                <p class="text-xs text-blue-800 leading-relaxed mb-3">
                    Phase 1: Recovery & Base Reinforcement. <br>
                    Phase 2: Sweet Spot Volume (SST). <br>
                    Phase 3: VO2 Max & Taper.
                </p>
                <button id="copy-stats" class="w-full bg-white border border-blue-200 text-blue-700 text-xs font-bold py-2 rounded-lg hover:bg-blue-100 flex items-center justify-center gap-2">
                    <span>📋 Copy Target: < 167W | 137bpm</span>
                </button>
            </div>
            
            <div id="week-nav" class="mb-6 flex overflow-x-auto py-2 gap-2 no-scrollbar"></div>
            
            <div id="week-details"></div>
        </main>

        <!-- Tab Content: Calisthenics -->
        <main id="calisthenics-content" class="bg-white p-6 rounded-xl shadow-lg hidden">
            <h2 class="text-2xl font-bold mb-4">Strength & Core</h2>
            <div class="space-y-4">
                <div class="bg-gray-50 p-4 rounded-lg border-l-4 border-blue-500">
                    <h3 class="font-bold">Weeks 2-4: Stability</h3>
                    <p class="text-sm text-gray-700">Focus on planks, side-planks, and bodyweight squats to support the increased SST volume.</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg border-l-4 border-blue-500">
                    <h3 class="font-bold">Weeks 5-7: Maintenance</h3>
                    <p class="text-sm text-gray-700">Reduce volume to keep legs fresh for VO2 Max intervals.</p>
                </div>
            </div>
        </main>

        <!-- Tab Content: Nutrition -->
        <main id="nutrition-content" class="bg-white p-6 rounded-xl shadow-lg hidden">
            <h2 class="text-2xl font-bold mb-4">Nutrition Strategy</h2>
            <div class="space-y-4">
                <div class="bg-orange-50 p-4 rounded-lg border-l-4 border-orange-500">
                    <h3 class="font-bold text-orange-800">Macro Cycling</h3>
                    <ul class="text-sm text-gray-700 list-disc pl-5 mt-2 space-y-2">
                        <li><strong>High Carb Days:</strong> Saturday (Workout days). Fuel with 60-90g carbs/hr.</li>
                        <li><strong>Moderate Days:</strong> Tuesday/Thursday (Group rides). Focus on 40-60g carbs/hr.</li>
                        <li><strong>Low Carb / High Protein:</strong> Rest days (Monday/Friday).</li>
                    </ul>
                </div>
            </div>
        </main>

        <footer class="mt-6 text-center text-gray-500 text-sm">
            <p>Cycle Build v3.0 • Full 8-Week Plan</p>
        </footer>
    </div>

    <script type="module">
        const cyclingPlan = {
            weeks: [
                {
                    week: 1,
                    title: "Recovery & Audax Reset",
                    days: [
                        { day: "Monday (Rest)", description: "Total rest." },
                        { day: "Tuesday (Bude Ride)", description: "COMPLETED. Effort: High (HR 150+)." },
                        { day: "Wednesday (Rest Day)", description: "**MANDATORY REST.** No cycling. Nerve recovery." },
                        { day: "Thursday (Easy Group Ride)", description: "Short/Easy route. Draft discipline. Cap HR at 137bpm." },
                        { day: "Friday (Rest Day)", description: "Total rest." },
                        { day: "Saturday (SST #1)", description: "MyWhoosh: **SST #1**. (2 x 15m @ 88-92% FTP). If tired, 90m Z2." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 2,
                    title: "Block 1: SST Base",
                    days: [
                        { day: "Monday (Zone 2)", description: "60-90m Z2 Aerobic. Maintain 85-95rpm." },
                        { day: "Tuesday (Group Ride)", description: "Standard Tuesday route. Stay in Z2/Z3." },
                        { day: "Wednesday (Active Recovery)", description: "30m Z1 Spin." },
                        { day: "Thursday (Group Ride)", description: "Focus on steady climbing efforts." },
                        { day: "Friday (Rest Day)", description: "Total rest." },
                        { day: "Saturday (SST #2)", description: "MyWhoosh: **SST #2** (3 x 12m @ Sweet Spot)." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 3,
                    title: "Block 1: Volume Build",
                    days: [
                        { day: "Monday (Zone 2)", description: "90m Z2. Focus on flat terrain." },
                        { day: "Tuesday (Group Ride)", description: "Incorporate some 'over-threshold' climbs." },
                        { day: "Wednesday (Active Recovery)", description: "30m Z1 Spin." },
                        { day: "Thursday (Group Ride)", description: "Longer duration if possible." },
                        { day: "Friday (Rest Day)", description: "Total rest." },
                        { day: "Saturday (SST #3)", description: "MyWhoosh: **SST #3** (2 x 20m @ Sweet Spot)." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 4,
                    title: "Block 1: Recovery Week",
                    days: [
                        { day: "Monday (Rest)", description: "Total rest." },
                        { day: "Tuesday (Easy Ride)", description: "60m Z1/Z2. No hills." },
                        { day: "Wednesday (Rest)", description: "Total rest." },
                        { day: "Thursday (Easy Group Ride)", description: "Social pace only." },
                        { day: "Friday (Rest)", description: "Total rest." },
                        { day: "Saturday (FTP Test)", description: "MyWhoosh: **20m FTP Test**. Re-calibrate zones." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 5,
                    title: "Block 2: Threshold & Power",
                    days: [
                        { day: "Monday (Zone 2)", description: "60m Z2." },
                        { day: "Tuesday (Group Ride)", description: "Higher intensity efforts on climbs." },
                        { day: "Wednesday (Recovery)", description: "30m Z1." },
                        { day: "Thursday (Group Ride)", description: "Build endurance." },
                        { day: "Friday (Rest)", description: "Total rest." },
                        { day: "Saturday (Over-Unders)", description: "MyWhoosh: **Over-Under #1** (2 x 12m)." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 6,
                    title: "Block 2: VO2 Intro",
                    days: [
                        { day: "Monday (Zone 2)", description: "75m Z2." },
                        { day: "Tuesday (Group Ride)", description: "Focus on high cadence." },
                        { day: "Wednesday (Recovery)", description: "30m Z1." },
                        { day: "Thursday (Group Ride)", description: "Steady endurance." },
                        { day: "Friday (Rest)", description: "Total rest." },
                        { day: "Saturday (VO2 Max)", description: "MyWhoosh: **30/15 Intervals**. (2 sets of 8)." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 7,
                    title: "Block 2: Peak Intensity",
                    days: [
                        { day: "Monday (Zone 2)", description: "60m Z2." },
                        { day: "Tuesday (Group Ride)", description: "Maximum effort on designated sections." },
                        { day: "Wednesday (Recovery)", description: "30m Z1." },
                        { day: "Thursday (Group Ride)", description: "Maintain intensity." },
                        { day: "Friday (Rest)", description: "Total rest." },
                        { day: "Saturday (VO2 Max #2)", description: "MyWhoosh: **40/20 Efforts**. (3 sets of 6)." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                },
                {
                    week: 8,
                    title: "Taper & Arrival",
                    days: [
                        { day: "Monday (Rest)", description: "Total rest." },
                        { day: "Tuesday (Easy Spin)", description: "45m Z1/Z2." },
                        { day: "Wednesday (Travel)", description: "Rest day." },
                        { day: "Thursday (Opener)", description: "30m spin with 2 x 1m 'Openers' at FTP." },
                        { day: "Friday (The Big Ride)", description: "Target ride with son. Enjoy the legs!" },
                        { day: "Saturday (Recovery)", description: "Easy coffee spin." },
                        { day: "Sunday (Rest Day)", description: "Rest Day." }
                    ]
                }
            ]
        };

        let currentWeek = 1;

        function renderWeekNav() {
            const nav = document.getElementById('week-nav');
            if (!nav) return;
            nav.innerHTML = cyclingPlan.weeks.map(w => `
                <button onclick="window.setWeek(${w.week})" class="whitespace-nowrap text-sm py-2 px-6 rounded-full font-medium transition ${w.week === currentWeek ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}">
                    Week ${w.week}
                </button>
            `).join('');
        }

        window.setWeek = (w) => {
            currentWeek = w;
            renderWeekNav();
            renderWeekDetails();
        };

        function renderWeekDetails() {
            const week = cyclingPlan.weeks.find(w => w.week === currentWeek);
            const details = document.getElementById('week-details');
            if (!details || !week) return;
            details.innerHTML = `
                <div class="mb-4">
                    <h3 class="font-bold text-xl text-blue-900">${week.title}</h3>
                </div>
                <ul class="space-y-3">
                    ${week.days.map(d => `
                        <li class="bg-gray-50 p-4 rounded-xl shadow-inner border-l-4 border-blue-500 hover:bg-white transition duration-200">
                            <h4 class="font-bold text-gray-900">${d.day}</h4>
                            <p class="text-sm text-gray-600 mt-1">${d.description}</p>
                        </li>
                    `).join('')}
                </ul>
            `;
        }

        const tabs = ['cycling', 'calisthenics', 'nutrition'];
        tabs.forEach(tab => {
            const btn = document.getElementById(`${tab}-btn`);
            if (btn) {
                btn.onclick = () => {
                    tabs.forEach(t => {
                        document.getElementById(`${t}-content`).classList.add('hidden');
                        document.getElementById(`${t}-btn`).classList.replace('bg-blue-600', 'bg-gray-300');
                        document.getElementById(`${t}-btn`).classList.replace('text-white', 'text-gray-700');
                    });
                    document.getElementById(`${tab}-content`).classList.remove('hidden');
                    document.getElementById(`${tab}-btn`).classList.replace('bg-gray-300', 'bg-blue-600');
                    document.getElementById(`${tab}-btn`).classList.replace('text-gray-700', 'text-white');
                };
            }
        });

        const copyBtn = document.getElementById('copy-stats');
        const toast = document.getElementById('toast');
        if (copyBtn) {
            copyBtn.onclick = () => {
                const text = "Thursday Target: Power < 167W | HR Cap: 137bpm. STAY IN THE DRAFT.";
                const dummy = document.createElement("textarea");
                document.body.appendChild(dummy);
                dummy.value = text;
                dummy.select();
                document.execCommand("copy");
                document.body.removeChild(dummy);
                
                toast.style.display = 'block';
                setTimeout(() => { toast.style.display = 'none'; }, 2000);
            };
        }

        window.onload = () => {
            renderWeekNav();
            renderWeekDetails();
        };
    </script>
</body>
</html>
